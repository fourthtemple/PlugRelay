@prefix doap: <http://usefulinc.com/ns/doap#> .
@prefix lv2: <http://lv2plug.in/ns/lv2core#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<urn:plugrelay:example:unsupported-required>
  a lv2:Plugin ;
  doap:name "PlugRelay Unsupported Required LV2" ;
  lv2:binary <plugrelay-unsupported-required.so> ;
  lv2:requiredFeature <urn:plugrelay:unsupported-required-feature> ;
  rdfs:seeAlso <plugrelay-unsupported-required.ttl> .
