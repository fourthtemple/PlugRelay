@prefix doap: <http://usefulinc.com/ns/doap#> .
@prefix lv2: <http://lv2plug.in/ns/lv2core#> .

<urn:plugrelay:example:unsupported-required>
  a lv2:Plugin ;
  doap:name "PlugRelay Unsupported Required LV2" ;
  lv2:requiredFeature <urn:plugrelay:unsupported-required-feature> ;
  lv2:port [
    a lv2:InputPort, lv2:AudioPort ;
    lv2:index 0 ;
    lv2:symbol "in_l" ;
    lv2:name "Input L"
  ], [
    a lv2:OutputPort, lv2:AudioPort ;
    lv2:index 1 ;
    lv2:symbol "out_l" ;
    lv2:name "Output L"
  ] .
